  <div class="footer-separator">─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────</div>
  <footer>
    <span class="fl">mark takács © 2025 — all writing is my own</span>
    <div class="fr">
      <a href="https://savalera.com" target="_blank" rel="noopener" title="Savalera">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20M12 2a14.5 14.5 0 0 1 0 20M2 12h20"/></svg>
      </a>
      <a href="https://www.linkedin.com/in/takacsmark/" target="_blank" rel="noopener" title="LinkedIn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
      <a href="https://github.com/takacsmark" target="_blank" rel="noopener" title="GitHub">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
      </a>
      <a href="https://x.com/takacsmark" target="_blank" rel="noopener" title="X">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="mailto:mark@takacsmark.com" title="Email">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
    </div>
  </footer>
</div>

<style>
  .footer-wrapper {
    background: var(--bg);
    margin-top: 3rem;
  }

  .footer-separator {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 2.5rem;
    color: var(--rule);
    font-size: 0.5rem;
    line-height: 0.5rem;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  footer {
    max-width: 768px;
    margin: 0 auto;
    padding: 0.7rem 2.5rem;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  footer .fl {
    opacity: 0.5;
    color: var(--ink2);
  }

  footer .fr {
    display: flex;
    gap: 1.4rem;
    align-items: center;
  }

  footer a {
    color: var(--ink2);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s, color 0.2s;
    display: flex;
    align-items: center;
  }

  footer a:hover {
    opacity: 1;
    color: var(--teal);
  }

  footer a svg {
    display: block;
  }

  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      gap: 0.8rem;
      text-align: center;
      padding: 0.7rem 1.5rem;
    }

    .footer-separator {
      padding: 0 1.5rem;
    }

    footer .fr {
      justify-content: center;
    }
  }
</style>