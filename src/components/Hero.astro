---
// src/components/Hero.astro
---

<header>
  <div class="prompt-line">
    <span class="p-char">$</span>
    <span class="p-cmd">find</span>
    <span class="p-arg">/ -name "purpose"</span>
    <span class="p-arg">2>/dev/null</span>
  </div>
  <div class="hero-name">Blog <span class="by">by</span> Mark<span class="dim"> Takács</span></div>
  <div class="hero-tagline">
    <span class="tl-item">Indie AI researcher</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">builder</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">writer</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">thinker on human existence</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">digital artist</span>
  </div>
</header>
<div class="hero-separator">─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────</div>

<style>
  header {
    max-width: 768px;
    margin: 0 auto;
    padding: 1.2rem 1.5rem 2rem;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards 0.1s;
  }

  .prompt-line {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.88rem;
    color: var(--ink3);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .prompt-line .p-char { color: var(--pink); }
  .prompt-line .p-cmd  { color: var(--teal); }
  .prompt-line .p-arg  { color: var(--sapphire); }

  .hero-name {
    font-family: var(--bungee);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--ink);
    text-transform: uppercase;
  }

  .hero-name .dim { color: var(--sapphire); }
  .hero-name .by  { font-size: 0.6em; color: var(--ink3); vertical-align: middle; }

  .hero-tagline {
    margin-top: 0.55rem;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.88rem;
    color: var(--ink3);
    display: flex;
    flex-wrap: wrap;
    gap: 0 0;
  }

  .tl-item { color: var(--ink2); }
  .tl-sep  { color: var(--rule); padding: 0 0.45rem; }

  .hero-separator {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 1.5rem;
    color: var(--rule);
    font-size: 0.5rem;
    line-height: 0.5rem;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0.4;
  }

  @media (max-width: 768px) {
    header { padding: 2rem 1rem 1.6rem; }
    .hero-separator { padding: 0 1rem; }
  }
</style>
