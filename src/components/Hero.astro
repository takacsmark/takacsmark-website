---
// src/components/Hero.astro
---

<header>
  <div class="prompt-line">
    <span class="p-char">$</span>
    <span class="p-cmd">find</span>
    <span class="p-arg">/ -name "purpose"</span>
    <span class="p-arg">2>/dev/null</span>
  </div>
  <div class="hero-inner">
    <div>
      <div class="hero-name">MARK<br><span class="dim">TAKÁCS</span></div>
    </div>
  </div>
  <div class="hero-tagline">
    <span class="tl-item">Indie AI researcher</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">builder</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">writer</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">thinker on human existence</span>
    <span class="tl-sep">/</span>
    <span class="tl-item">Budapest</span>
  </div>
  <hr class="header-rule">
</header>

<style>
  header {
    max-width: 768px;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards 0.1s;
  }

  .prompt-line {
    font-size: 0.68rem;
    color: var(--ink3);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .prompt-line .p-char { color: var(--pink); }
  .prompt-line .p-cmd  { color: var(--teal); }
  .prompt-line .p-arg  { color: var(--sapphire); }

  .hero-name {
    font-family: var(--bungee);
    font-size: clamp(1.9rem, 4.4vw, 3.8rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 0.95;
    color: var(--ink);
    text-transform: uppercase;
  }

  .hero-name .dim { color: var(--sapphire); }

  .hero-tagline {
    margin-top: 1rem;
    font-size: 0.72rem;
    color: var(--ink3);
    display: flex;
    flex-wrap: wrap;
    gap: 0 0;
  }

  .tl-item { color: var(--ink2); }
  .tl-sep  { color: var(--rule); padding: 0 0.5rem; }
  .tl-item.hl { color: var(--teal); }

  .header-rule {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 1.8rem 0 0;
  }
</style>