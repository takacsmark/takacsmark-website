---
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { render } from 'astro:content';

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.data.title} | Mark Takács</title>
    <meta name="description" content={post.data.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;1,8..60,300;1,8..60,400&family=Bungee&display=swap" rel="stylesheet">
    <script is:inline>
      // Apply theme immediately to prevent flash
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark-mode');
        }
      })();
    </script>
  </head>
  <body>
    <TopBar />

    <div class="post-header">
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb-link">
          <span class="p-char">~</span>
        </a>
        <span class="breadcrumb-sep">/</span>
        <a href="/writing" class="breadcrumb-link">writing</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{post.slug}</span>
      </nav>

      <article>
        <header class="article-header">
          <h1 class="article-title">{post.data.title}</h1>

          <div class="article-meta">
            <span class="meta-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </div>

          {post.data.description && (
            <p class="article-description">{post.data.description}</p>
          )}
        </header>

        <div class="article-content">
          <Content />
        </div>
      </article>
    </div>

    <NewsletterSignup />

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="bottom-tags">
        {post.data.tags.map(tag => (
          <a href={`/blog/tag/${tag.toLowerCase()}`} class={`tag tag-${tag.toLowerCase()}`}>{tag}</a>
        ))}
      </div>
    )}

    <section class="share-section">
      <span class="share-label">Share this post on:</span>
      <div class="share-links">
        <a class="share-btn" id="share-x" href="#" target="_blank" rel="noopener noreferrer">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a class="share-btn" id="share-bluesky" href="#" target="_blank" rel="noopener noreferrer">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
          <span>bluesky</span>
        </a>
        <a class="share-btn" id="share-linkedin" href="#" target="_blank" rel="noopener noreferrer">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span>linkedin</span>
        </a>
        <a class="share-btn" id="share-whatsapp" href="#" target="_blank" rel="noopener noreferrer">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          <span>whatsapp</span>
        </a>
        <a class="share-btn" id="share-facebook" href="#" target="_blank" rel="noopener noreferrer">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          <span>facebook</span>
        </a>
        <a class="share-btn" id="share-telegram" href="#" target="_blank" rel="noopener noreferrer">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          <span>telegram</span>
        </a>
        <a class="share-btn" id="share-email" href="#">
          <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
          <span>email</span>
        </a>
      </div>
    </section>

    {(prevPost || nextPost) && (
      <nav class="post-nav">
        <div class="post-nav-grid">
          {prevPost ? (
            <a href={`/blog/${prevPost.slug}`} class="post-nav-card post-nav-prev">
              <span class="nav-direction">← prev post</span>
              <span class="nav-post-title">{prevPost.data.title}</span>
              <span class="nav-post-date">{prevPost.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </a>
          ) : <div />}
          {nextPost ? (
            <a href={`/blog/${nextPost.slug}`} class="post-nav-card post-nav-next">
              <span class="nav-direction">next post →</span>
              <span class="nav-post-title">{nextPost.data.title}</span>
              <span class="nav-post-date">{nextPost.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </a>
          ) : <div />}
        </div>
      </nav>
    )}

    <Footer />

    <script is:inline>
      // Theme toggle handler
      document.addEventListener('DOMContentLoaded', function() {
        const themeCheck = document.getElementById('theme-check');

        // Sync checkbox with saved theme
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
          themeCheck.checked = true;
        }

        // Toggle theme on change
        themeCheck?.addEventListener('change', function() {
          if (this.checked) {
            localStorage.setItem('theme', 'dark');
            document.documentElement.classList.add('dark-mode');
          } else {
            localStorage.setItem('theme', 'light');
            document.documentElement.classList.remove('dark-mode');
          }
        });
      });
    </script>

    <script is:inline>
      // Share links
      document.addEventListener('DOMContentLoaded', function() {
        var url = encodeURIComponent(window.location.href);
        var title = encodeURIComponent(
          (document.querySelector('.article-title') || {}).textContent?.trim() || document.title
        );
        var links = {
          'share-x':        'https://x.com/intent/post?text=' + title + '&url=' + url,
          'share-bluesky':  'https://bsky.app/intent/compose?text=' + title + '%20' + url,
          'share-linkedin': 'https://www.linkedin.com/sharing/share-offsite/?url=' + url,
          'share-whatsapp': 'https://wa.me/?text=' + title + '%20' + url,
          'share-facebook': 'https://www.facebook.com/sharer/sharer.php?u=' + url,
          'share-telegram': 'https://t.me/share/url?url=' + url + '&text=' + title,
          'share-email':    'mailto:?subject=' + title + '&body=' + url,
        };
        Object.keys(links).forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.href = links[id];
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── RESET ── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ── CSS CUSTOM PROPERTIES ── */
  :root {
    --bg:       #ffffff;
    --bg2:      #f5f5f7;
    --ink:      #28282e;
    --ink2:     #4c4f69;
    --ink3:     #9ca0b0;
    --rule:     #e0e0e8;

    /* Charm / Bubbletea accent palette */
    --pink:     #ea76cb;
    --mauve:    #8839ef;
    --teal:     #179299;
    --sapphire: #00d4f5;
    --green:    #40a02b;
    --peach:    #fe640b;
    --lavender: #7287fd;

    --mono: 'JetBrains Mono', 'Courier New', monospace;
    --serif: 'Source Serif 4', Georgia, serif;
    --bungee: 'Bungee', sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 13.5px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ── DARK MODE ── */
  .dark-mode,
  body:has(#theme-check:checked) {
    --bg:   #1e1e2e;
    --bg2:  #181825;
    --ink:  #cdd6f4;
    --ink2: #bac2de;
    --ink3: #6c7086;
    --rule: #313244;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .topbar {
      padding: 0.35rem 1.5rem;
    }

    .post-header {
      padding: 1.5rem 1rem 0;
    }

    footer {
      flex-direction: column;
      gap: 0.8rem;
      text-align: center;
      padding: 0.7rem 1.5rem;
    }

    footer .fr {
      justify-content: center;
    }
  }
</style>

<style>
  .post-header {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards 0.1s;
  }

  .breadcrumb {
    font-size: 0.88rem;
    color: var(--ink3);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb .p-char {
    color: var(--pink);
  }

  .breadcrumb-link {
    color: var(--ink2);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-link:hover {
    color: var(--sapphire);
  }

  .breadcrumb-sep {
    color: var(--rule);
  }

  .breadcrumb-current {
    color: var(--ink3);
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-title {
    font-family: var(--mono);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }

  .meta-date {
    font-size: 0.78rem;
    color: var(--ink3);
    letter-spacing: 0.05em;
  }

  .meta-sep {
    color: var(--rule);
    font-size: 0.6rem;
  }

  .meta-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    padding: 0.1rem 0.45rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .tag-ai     { background: #e8f0ff; color: var(--lavender); border: 1px solid #c5d0f8; }
  .tag-psych  { background: #f0fae8; color: var(--green);    border: 1px solid #c5e8b0; }
  .tag-res    { background: #fff0f8; color: var(--pink);     border: 1px solid #f8c5e0; }
  .tag-research { background: #fff0f8; color: var(--pink);   border: 1px solid #f8c5e0; }
  .tag-exist  { background: #f3efff; color: var(--mauve);    border: 1px solid #d5c5f8; }
  .tag-existence { background: #f3efff; color: var(--mauve); border: 1px solid #d5c5f8; }
  .tag-philosophy { background: #f3efff; color: var(--mauve); border: 1px solid #d5c5f8; }
  .tag-tech   { background: #e8f8ff; color: var(--sapphire); border: 1px solid #b8e0f0; }
  .tag-work   { background: #e8f8ff; color: var(--sapphire); border: 1px solid #b8e0f0; }

  .article-description {
    font-family: var(--mono);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink2);
    line-height: 1.75;
    padding: 1rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .article-content {
    font-family: var(--mono);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: 4rem;
  }

  /* ── ARTICLE CONTENT TYPOGRAPHY ── */
  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    font-family: var(--mono);
    font-weight: 700;
    color: var(--ink);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .article-content :global(h1) { font-size: 2rem; }
  .article-content :global(h2) { font-size: 1.5rem; }
  .article-content :global(h3) { font-size: 1.25rem; }
  .article-content :global(h4) { font-size: 1.1rem; }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(a) {
    color: var(--sapphire);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 0.2em;
    transition: text-decoration-color 0.2s;
  }

  .article-content :global(a:hover) {
    text-decoration-color: var(--sapphire);
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }

  .article-content :global(em) {
    font-style: italic;
  }

  .article-content :global(code) {
    font-family: var(--mono);
    font-size: 0.88em;
    background: var(--bg2);
    color: var(--pink);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    border: 1px solid var(--rule);
  }

  .article-content :global(pre) {
    font-family: var(--mono);
    font-size: 1rem;
    line-height: 1.6;
    background: var(--bg2);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 1.2rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .article-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--ink);
  }

  /* Shiki dual theme support */
  .article-content :global(pre.astro-code) {
    background: var(--bg2) !important;
  }

  /* Override inline color styles to use dark theme in dark mode */
  .dark-mode .article-content :global(pre.astro-code span),
  body:has(#theme-check:checked) .article-content :global(pre.astro-code span) {
    color: var(--shiki-dark) !important;
  }

  /* Override background color for code blocks in dark mode */
  .dark-mode .article-content :global(pre.astro-code),
  body:has(#theme-check:checked) .article-content :global(pre.astro-code) {
    background-color: var(--shiki-dark-bg) !important;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--sapphire);
    padding-left: 1.2rem;
    margin: 1.5rem 0;
    color: var(--ink2);
    font-style: italic;
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--rule);
    margin: 1.5rem 0;
  }

  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .article-content :global(th) {
    background: var(--bg2);
    color: var(--ink);
    font-weight: 600;
    padding: 0.7rem;
    text-align: left;
    border: 1px solid var(--rule);
  }

  .article-content :global(td) {
    padding: 0.7rem;
    border: 1px solid var(--rule);
  }

  .bottom-tags {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 1.5rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .bottom-tags { padding: 0 1.5rem 1.5rem; }
  }

  /* ── SHARE SECTION ── */
  .share-section {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 1.5rem 2.5rem;
  }

  .share-label {
    display: block;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
    padding-top: 1.5rem;
  }

  .share-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.65rem;
    font-size: 0.78rem;
    font-family: var(--mono);
