---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Mark Takács" description="Learn more about Mark Takács - indie AI researcher, builder, writer, and thinker on human existence.">
  <Fragment slot="head">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:title" content="About | Mark Takács" />
    <meta property="og:description" content="Learn more about Mark Takács - indie AI researcher, builder, writer, and thinker on human existence." />
    <meta property="og:site_name" content="Mark Takács" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="About | Mark Takács" />
    <meta name="twitter:description" content="Learn more about Mark Takács - indie AI researcher, builder, writer, and thinker on human existence." />
  </Fragment>

  <div class="about-header">
    <div class="prompt-line">
      <span class="p-char">$</span>
      <span class="p-cmd">cat</span>
      <span class="p-arg">~/about.txt</span>
    </div>
    <h1 class="page-title"><span class="title-accent">About</span></h1>
    <hr class="header-rule">
  </div>

  <div class="layout">
    <main class="about-content">
      <section class="about-section">
        <h2 class="section-title">// Who I Am</h2>
        <p>I'm Mark Takács, an indie AI researcher, builder, and writer based in Budapest. I spend my time exploring the intersection of artificial intelligence, psychology, and what it means to be human in an age of intelligent machines.</p>
      </section>

      <section class="about-section">
        <h2 class="section-title">// What I Do</h2>
        <p>I build AI systems, conduct independent research, and write about the philosophical implications of our technological future. My work focuses on understanding intelligence—both artificial and human—from first principles.</p>
        <p>Recent projects include quantizing multilingual language models, simulating agent dialogues, and exploring the cognitive patterns that emerge when systems start to break down.</p>
      </section>

      <section class="about-section">
        <h2 class="section-title">// What I Think About</h2>
        <p>The questions that drive my work aren't purely technical. I'm interested in:</p>
        <ul>
          <li>How AI challenges our assumptions about consciousness and understanding</li>
          <li>The psychological patterns we share with the systems we build</li>
          <li>What trauma and adaptation teach us about intelligent behavior</li>
          <li>The gap between simulation and genuine comprehension</li>
          <li>How we construct meaning in systems designed to process patterns</li>
        </ul>
      </section>

      <section class="about-section">
        <h2 class="section-title">// Get in Touch</h2>
        <p>I'm always interested in conversations about AI, consciousness, and the philosophical implications of what we're building.</p>
        <div class="contact-links">
          <a href="mailto:mark@takacsmark.com" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            mark@takacsmark.com
          </a>
          <a href="https://savalera.com" target="_blank" rel="noopener" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20M12 2a14.5 14.5 0 0 1 0 20M2 12h20"/></svg>
            Savalera
          </a>
          <a href="https://github.com/takacsmark" target="_blank" rel="noopener" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            GitHub
          </a>
          <a href="https://x.com/takacsmark" target="_blank" rel="noopener" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X / Twitter
          </a>
          <a href="https://www.linkedin.com/in/takacsmark/" target="_blank" rel="noopener" class="contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .about-header {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards 0.1s;
  }

  .prompt-line {
    font-size: 0.88rem;
    color: var(--ink3);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .prompt-line .p-char { color: var(--pink); }
  .prompt-line .p-cmd  { color: var(--sapphire); }
  .prompt-line .p-arg  { color: var(--sapphire); }

  .page-title {
    font-family: var(--bungee);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--ink);
    text-transform: uppercase;
  }

  .title-accent { color: var(--sapphire); }

  .header-rule {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 1.8rem 0 0;
  }

  .layout {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .about-content {
    margin-top: 2rem;
  }

  .about-section {
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }

  .about-section:nth-child(1) { animation-delay: 0.2s; }
  .about-section:nth-child(2) { animation-delay: 0.3s; }
  .about-section:nth-child(3) { animation-delay: 0.4s; }
  .about-section:nth-child(4) { animation-delay: 0.5s; }

  .section-title {
    font-family: var(--mono);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pink);
    margin-bottom: 1rem;
  }

  .about-section p {
    font-family: var(--mono);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: 1.2rem;
  }

  .about-section ul {
    font-family: var(--mono);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
    margin-left: 1.5rem;
    list-style: none;
  }

  .about-section li {
    margin-bottom: 0.8rem;
    position: relative;
    padding-left: 1rem;
  }

  .about-section li::before {
    content: '→';
    position: absolute;
    left: -0.5rem;
    color: var(--sapphire);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--ink2);
    text-decoration: none;
    font-family: var(--mono);
    font-size: 1.05rem;
    padding: 0.8rem 1rem;
    background: var(--bg2);
    border: 1px solid var(--rule);
    border-radius: 4px;
    transition: all 0.2s;
  }

  .contact-link:hover {
    color: var(--sapphire);
    border-color: var(--sapphire);
    background: var(--bg);
  }

  .contact-link svg {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .about-header { padding: 1.5rem 1rem 0; }
    .layout { padding: 1.5rem 1rem 3rem; }
  }
</style>
