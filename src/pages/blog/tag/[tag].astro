---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Article from '../../../components/Article.astro';
import { getTagStyle } from '../../../utils/tagColor';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tagMap = new Map<string, { label: string; posts: typeof posts }>();

  posts.forEach(post => {
    (post.data.tags ?? []).forEach(tag => {
      const key = tag.toLowerCase();
      if (!tagMap.has(key)) tagMap.set(key, { label: tag, posts: [] });
      tagMap.get(key)!.posts.push(post);
    });
  });

  return [...tagMap.entries()].map(([tag, { label, posts }]) => ({
    params: { tag },
    props: {
      tagLabel: label,
      posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tagLabel, posts } = Astro.props;
const { tag } = Astro.params;
---

<BaseLayout title={`#${tagLabel} | Mark Takács`} description={`All posts tagged ${tagLabel} by Mark Takács.`}>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`#${tagLabel} | Mark Takács`} />
    <meta property="og:description" content={`All posts tagged ${tagLabel} by Mark Takács.`} />
    <meta property="og:site_name" content="Mark Takács" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`#${tagLabel} | Mark Takács`} />
    <meta name="twitter:description" content={`All posts tagged ${tagLabel} by Mark Takács.`} />
  </Fragment>

  <div class="tag-header">
    <nav class="breadcrumb">
      <a href="/" class="breadcrumb-link"><span class="p-char">~</span></a>
      <span class="breadcrumb-sep">/</span>
      <a href="/writing" class="breadcrumb-link">writing</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">#{tag}</span>
    </nav>

    <div class="prompt-line">
      <span class="p-char">$</span>
      <span class="p-cmd">grep</span>
      <span class="p-flag">-r</span>
      <span class="p-arg">"{tag}"</span>
      <span class="p-path">~/writing/</span>
    </div>
    <h1 class="page-title"><span class="title-dim">#{tagLabel}</span></h1>
    <p class="page-subtitle">{posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged <span class="tag" style={getTagStyle(tag)}>{tagLabel}</span></p>
    <hr class="header-rule">
  </div>

  <div class="layout">
    <main>
      {posts.map(post => (
        <Article post={post} />
      ))}
    </main>
  </div>
</BaseLayout>

<style>
  .tag-header {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards 0.1s;
  }

  .breadcrumb {
    font-size: 0.88rem;
    color: var(--ink3);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb .p-char { color: var(--pink); }

  .breadcrumb-link {
    color: var(--ink2);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-link:hover { color: var(--sapphire); }
  .breadcrumb-sep { color: var(--rule); }
  .breadcrumb-current { color: var(--ink3); }

  .prompt-line {
    font-size: 0.88rem;
    color: var(--ink3);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .prompt-line .p-char  { color: var(--pink); }
  .prompt-line .p-cmd   { color: var(--sapphire); }
  .prompt-line .p-flag  { color: var(--ink3); }
  .prompt-line .p-arg   { color: var(--peach); }
  .prompt-line .p-path  { color: var(--sapphire); }

  .page-title {
    font-family: var(--bungee);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--ink);
    text-transform: uppercase;
  }

  .title-dim { color: var(--ink3); }

  .page-subtitle {
    margin-top: 1rem;
    font-size: 0.88rem;
    color: var(--ink2);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.1rem 0.45rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .header-rule {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 1.8rem 0 0;
  }

  .layout {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  @media (max-width: 768px) {
    .tag-header { padding: 1.5rem 1rem 0; }
    .layout { padding: 1.5rem 1rem 3rem; }
  }
</style>
