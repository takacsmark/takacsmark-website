---
// src/pages/writing.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Article from '../components/Article.astro';

const posts = await getCollection('blog');
// Sort posts by date, newest first
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Writing | Mark Takács" description="All writing by Mark Takács on AI, psychology, research, and human existence.">
  <Fragment slot="head">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:title" content="Writing | Mark Takács" />
    <meta property="og:description" content="All writing by Mark Takács on AI, psychology, research, and human existence." />
    <meta property="og:site_name" content="Mark Takács" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Writing | Mark Takács" />
    <meta name="twitter:description" content="All writing by Mark Takács on AI, psychology, research, and human existence." />
  </Fragment>

  <div class="writing-header">
    <div class="prompt-line">
      <span class="p-char">$</span>
      <span class="p-cmd">ls</span>
      <span class="p-arg">-lah ~/writing/</span>
    </div>
    <h1 class="page-title">All <span class="title-accent">Writing</span></h1>
    <p class="page-subtitle">{sortedPosts.length} {sortedPosts.length === 1 ? 'post' : 'posts'} on AI, psychology, research, and existence</p>
    <hr class="header-rule">
  </div>

  <div class="layout">
    <main id="writing">
      {sortedPosts.map(post => (
        <Article post={post} />
      ))}
    </main>
  </div>
</BaseLayout>

<style>
  .writing-header {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    opacity: 0;
    animation: fadeUp 0.55s ease forwards 0.1s;
  }

  .prompt-line {
    font-size: 0.88rem;
    color: var(--ink3);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .prompt-line .p-char { color: var(--pink); }
  .prompt-line .p-cmd  { color: var(--teal); }
  .prompt-line .p-arg  { color: var(--sapphire); }

  .page-title {
    font-family: var(--bungee);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--ink);
    text-transform: uppercase;
  }

  .title-accent { color: var(--sapphire); }

  .page-subtitle {
    margin-top: 1rem;
    font-size: 0.88rem;
    color: var(--ink2);
  }

  .header-rule {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 1.8rem 0 0;
  }

  .layout {
    max-width: 768px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  @media (max-width: 768px) {
    .writing-header { padding: 1.5rem 1rem 0; }
    .layout { padding: 1.5rem 1rem 3rem; }
  }
</style>
